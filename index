  function calcSky(){
    const Q = {
      bar: clamp0(qs('#sky_bar').value),
      p3: clamp0(qs('#sky_3p').value),
      p3promo: clamp0(qs('#sky_3p_promo').value),
      tv: clamp0(qs('#sky_tv').value),
      wifi: clamp0(qs('#sky_wifi').value),
      wifitv: clamp0(qs('#sky_wifi_tvclient').value),
      wifipn: clamp0(qs('#sky_wifi_prova_nc').value),
      wifipc: clamp0(qs('#sky_wifi_prova_c').value),
      provanc: clamp0(qs('#sky_prova_nc').value),
      provac: clamp0(qs('#sky_prova_c').value),
      glass: clamp0(qs('#sky_glass').value),
      wifibus: clamp0(qs('#sky_wifi_bus').value),
    };

    let pts=0, e=0, totalItems=0, contractsSky=0, prove=0;
    for(const k of Object.keys(Q)){
      const qty = Q[k];
      totalItems += qty;
      pts += qty * (CFG.sky.products[k].pts || 0);
    }

    const tier = pickSkyTierByPoints(pts);

    for(const k of Object.keys(Q)){
      const qty = Q[k];
      e += qty * (CFG.sky.products[k].pay[tier] || 0);
      if(k==='provanc' || k==='provac' || k==='wifipn' || k==='wifipc') prove += qty;
      if(k!=='provanc' && k!=='provac') contractsSky += qty;
    }

    const triggerQty = clamp0(qs('#sky_extra_trigger_qty').value);
    const triggerValid = triggerQty > 0 && triggerQty <= contractsSky;

    const total3p = Q.p3 + Q.p3promo;
    const totalTv = Q.tv;

    const extra3pApplied = triggerValid && total3p > 0 ? total3p : 0;
    const extraTvApplied = triggerValid && totalTv > 0 ? totalTv : 0;

    e += extra3pApplied * CFG.sky.extra3p;
    e += extraTvApplied * CFG.sky.extraTv;

    return {
      Q, pts:round2(pts), tier, eur:e, totalItems, contractsSky, prove,
      triggerQty, triggerValid, extra3pApplied, extraTvApplied,
      next:nextStep(round2(pts),[5,8,12,20])
    };
  }

