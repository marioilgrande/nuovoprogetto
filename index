<!doctype html>
<html lang="it">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,viewport-fit=cover" />
  <title>Gare E2K • Marzo 2026</title>

  <style>
    :root{
      --base:#d6006b;
      --fastweb:#e4b002;
      --tiscali:#3b2783;
      --sky:#cf01cf;
      --acea:#05a8b0;
      --ho:#5f58a1;
      --eff:#16a34a;
      --rent:#0b2a55;
      --bg:#eef2ff;
      --card:#ffffff;
      --text:#0f172a;
      --muted:#64748b;
      --border:#e5e7eb;
      --radius:18px;
      --shadow:0 18px 40px rgba(15,23,42,.10);
      --shadowSoft:0 10px 24px rgba(15,23,42,.08);
      --ok:#16a34a;
      --warn:#f59e0b;
      --bad:#ef4444;
    }

    *{ box-sizing:border-box; }
    html,body{ height:100%; }
    body{
      margin:0;
      font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial;
      color:var(--text);
      background:
        radial-gradient(1200px 700px at 10% -10%, rgba(214,0,107,.14), transparent 55%),
        radial-gradient(1100px 700px at 90% 0%, rgba(5,168,176,.14), transparent 55%),
        linear-gradient(180deg, #eef2ff, #f7f7fb 35%, #ffffff);
      -webkit-text-size-adjust:100%;
      overscroll-behavior-y:contain;
    }

    .shell{
      max-width:1180px;
      margin:0 auto;
      padding:
        calc(22px + env(safe-area-inset-top))
        calc(16px + env(safe-area-inset-right))
        calc(46px + env(safe-area-inset-bottom))
        calc(16px + env(safe-area-inset-left));
    }

    .header{
      display:flex; align-items:flex-start; justify-content:space-between; gap:14px;
      margin-bottom:14px;
    }
    .title{ font-size:44px; line-height:1; font-weight:950; letter-spacing:-.6px; }
    .subtitle{ margin-top:10px; color:var(--muted); font-weight:800; }
    .pill{
      height:26px; width:380px; border-radius:999px;
      background: linear-gradient(90deg, rgba(214,0,107,.22), rgba(214,0,107,.06));
      box-shadow: 0 10px 20px rgba(214,0,107,.10);
    }

    .topActions{
      display:flex; gap:10px; flex-wrap:wrap; align-items:center; justify-content:flex-end; margin-top:2px;
    }
    .btn{
      cursor:pointer;
      border:1px solid var(--border);
      background:#fff;
      padding:10px 12px;
      border-radius:14px;
      font-weight:950;
      box-shadow: var(--shadowSoft);
      user-select:none;
      white-space:nowrap;
      touch-action: manipulation;
      -webkit-tap-highlight-color: transparent;
    }
    .btn.primary{
      border-color: rgba(214,0,107,.30);
      background: linear-gradient(90deg, rgba(214,0,107,.14), rgba(255,255,255,1));
    }

    .kpis{
      display:grid;
      grid-template-columns: repeat(3, minmax(0,1fr));
      gap:14px;
      margin:14px 0 14px;
    }
    .kpiCard{
      background:var(--card);
      border:1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding:16px 18px;
    }
    .kpiCard .k{ color:var(--muted); font-weight:900; }
    .kpiCard .v{ font-size:28px; font-weight:950; margin-top:6px; }

    .brandTotals{
      display:grid;
      grid-template-columns: repeat(5, minmax(0,1fr));
      gap:12px;
      margin:10px 0 14px;
    }
    .bCard{
      background:var(--card);
      border:1px solid var(--border);
      border-radius:18px;
      box-shadow:var(--shadowSoft);
      padding:12px 14px;
      overflow:hidden;
      position:relative;
    }
    .bCard .bTop{
      display:flex; align-items:center; justify-content:space-between; gap:10px; margin-bottom:8px;
    }
    .bCard .bName{
      font-weight:950; font-size:13px; color:var(--muted); letter-spacing:.2px;
    }
    .bCard .bVal{
      font-weight:950; font-size:22px; line-height:1;
    }
    .bCard .bSub{
      font-size:11px; color:var(--muted); font-weight:850; line-height:1.25;
      white-space:normal; overflow:visible; text-overflow:unset; word-break:break-word; margin-top:2px;
    }
    .bAccent{
      position:absolute; right:-34px; top:-24px; width:120px; height:120px; border-radius:50%; opacity:.14; pointer-events:none;
    }

    .insights{
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 18px;
      box-shadow: var(--shadowSoft);
      padding: 14px 16px;
      margin: 0 0 18px;
    }
    .insTitle{ font-weight:950; letter-spacing:-.2px; font-size:14px; margin-bottom:8px; }
    .insLine{ font-weight:900; color:#0f172a; font-size:13px; line-height:1.35; margin-top:6px; }
    .insLine span{ color: var(--muted); font-weight:850; }

    .grid{
      display:grid;
      grid-template-columns: repeat(3, minmax(0,1fr));
      gap:16px;
      margin-top:4px;
      isolation:isolate;
    }
    .tile{
      position:relative;
      z-index:0;
      border:1px solid var(--border);
      border-radius:22px;
      background:#fff;
      box-shadow:var(--shadow);
      padding:18px 18px 16px;
      min-height:118px;
      cursor:pointer;
      overflow:hidden;
      text-align:left;
      touch-action: manipulation;
      -webkit-tap-highlight-color: transparent;
      transition:transform .15s ease;
      width:100%;
      margin:0;
      appearance:none;
      -webkit-appearance:none;
      display:block;
    }
    .tile h3{ margin:0; font-size:26px; font-weight:950; letter-spacing:-.2px; }
    .tile p{ margin:8px 0 0; color:var(--muted); font-weight:850; line-height:1.25; font-size:18px; }
    .tile:focus,.tile:focus-visible{ outline:none; z-index:0; }
    .accent{
      position:absolute; right:-40px; top:8px; width:180px; height:180px; border-radius:50%; opacity:.16; pointer-events:none;
    }
    .tile[data-open="multibrand"]{ grid-column:span 2 !important; }

    @media (hover:hover) and (pointer:fine){
      .tile:hover{ transform:translateY(-1px); }
    }
    @media (hover:none) and (pointer:coarse){
      .tile:hover{ transform:none !important; }
      .tile:active{ transform:translateY(-1px); }
    }

    .panelWrap{ display:none; margin-top:18px; }
    .panel{
      background:var(--card);
      border:1px solid var(--border);
      border-radius:22px;
      box-shadow:var(--shadow);
      overflow:hidden;
    }
    .panelHd{
      padding:16px 18px;
      border-bottom:1px solid var(--border);
      display:flex; align-items:center; justify-content:space-between; gap:10px;
      background: linear-gradient(180deg, rgba(15,23,42,.03), rgba(15,23,42,0));
      flex-wrap:wrap;
    }
    .panelHd .left{ display:flex; align-items:center; gap:12px; }
    .dot{
      width:12px; height:12px; border-radius:999px; background: var(--base); box-shadow: 0 0 0 4px rgba(214,0,107,.12);
    }
    .panelHd .t1{ font-weight:950; font-size:16px; }
    .panelHd .t2{ color:var(--muted); font-weight:850; font-size:12px; margin-top:2px; }
    .panelBd{ padding:18px; }

    .row2{
      display:grid;
      grid-template-columns:1fr;
      gap:12px;
    }
    @media(min-width:920px){ .row2{ grid-template-columns:1fr 1fr; } }

    .field{ display:flex; flex-direction:column; gap:6px; }
    .label{
      font-size:12px; color:var(--muted); font-weight:900;
      display:flex; justify-content:space-between; align-items:center;
    }
    .hint{ font-size:11px; color:var(--muted); font-weight:800; }

    input[type="number"], select{
      width:100%;
      padding:12px 12px;
      border-radius:14px;
      border:1px solid var(--border);
      background:#fff;
      font-size:14px;
      outline:none;
    }
    input[type="number"]:focus, select:focus{
      border-color: rgba(214,0,107,.32);
      box-shadow: 0 0 0 4px rgba(214,0,107,.10);
    }
    input[type="number"]::placeholder{ color:#94a3b8; }

    .subtabs{ display:flex; flex-wrap:wrap; gap:8px; }
    .subbtn{
      cursor:pointer;
      padding:9px 10px;
      border-radius:999px;
      border:1px solid var(--border);
      background:#fff;
      font-weight:950;
      font-size:12px;
      user-select:none;
      touch-action: manipulation;
      -webkit-tap-highlight-color: transparent;
    }
    .subbtn.active{
      border-color: rgba(15,23,42,.28);
      box-shadow: 0 10px 18px rgba(15,23,42,.06);
    }

    .miniGrid{
      display:grid;
      grid-template-columns:1fr;
      gap:12px;
    }
    @media(min-width:920px){
      .miniGrid{ grid-template-columns:repeat(4, minmax(0,1fr)); }
    }

    .boxGroup{
      border:1px solid var(--border);
      border-radius:16px;
      padding:12px;
      background:linear-gradient(180deg, rgba(15,23,42,.02), rgba(15,23,42,0));
    }
    .boxGroup .gTitle{
      font-size:12px;
      font-weight:950;
      color:var(--text);
      margin-bottom:8px;
    }

    .hide{ display:none !important; }
    .hr{ height:1px; background: var(--border); margin:14px 0; }

    .resultBox{
      border:1px solid var(--border);
      border-radius:18px;
      padding:14px;
      background: linear-gradient(180deg, rgba(15,23,42,.02), rgba(15,23,42,0));
    }
    .resultBox .rTop{
      display:flex; align-items:flex-end; justify-content:space-between; gap:10px; flex-wrap:wrap;
    }
    .resultBox .big{ font-weight:950; font-size:22px; }
    .resultBox .small{ color:var(--muted); font-weight:850; font-size:12px; }

    .mono{
      margin-top:10px;
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
      font-size:12px;
      white-space:pre-line;
      line-height:1.35;
      color:#0f172a;
    }

    .statusPill{
      display:inline-flex; align-items:center; gap:8px;
      padding:8px 10px;
      border-radius:999px;
      border:1px solid var(--border);
      background:#fff;
      font-weight:950;
      font-size:12px;
    }
    .statusPill .pDot{ width:10px; height:10px; border-radius:50%; background:var(--ok); }
    .statusPill.warn .pDot{ background:var(--warn); }
    .statusPill.bad .pDot{ background:var(--bad); }

    .errBanner{
      display:none;
      margin-top:14px;
      border:1px solid rgba(239,68,68,.35);
      background: rgba(239,68,68,.08);
      border-radius:16px;
      padding:12px 14px;
      color:#991b1b;
      font-weight:850;
      box-shadow: var(--shadowSoft);
      white-space:pre-line;
    }

    @media(max-width:980px){
      .grid{ grid-template-columns:1fr; gap:22px; }
      .kpis{ grid-template-columns:1fr; }
      .brandTotals{ grid-template-columns: repeat(2, minmax(0,1fr)); }
      .tile[data-open="multibrand"]{ grid-column:auto !important; }
    }

    @media(max-width:640px){
      .shell{
        padding:
          calc(16px + env(safe-area-inset-top))
          calc(12px + env(safe-area-inset-right))
          calc(42px + env(safe-area-inset-bottom))
          calc(12px + env(safe-area-inset-left));
      }
      .title{ font-size:34px; }
      .pill{ width:200px; height:22px; }
      .header{ flex-direction:column; align-items:flex-start; }
      .topActions{ width:100%; justify-content:flex-start; }
      .btn{ width:100%; text-align:center; padding:12px 14px; }
      .kpiCard .v{ font-size:26px; }
      .tile h3{ font-size:24px; }
      .tile p{ font-size:16px; }
      .accent{ right:-64px; top:18px; width:170px; height:170px; }
      .panelBd{ padding:14px; }
      input[type="number"], select{ padding:13px 12px; font-size:16px; }
      .bCard .bVal{ font-size:20px; }
      .bCard .bSub{ font-size:11px; }
      .insTitle{ font-size:14px; }
      .insLine{ font-size:13px; }
      .grid{ gap:24px; }
      .panelHd{
        position: sticky;
        top: calc(env(safe-area-inset-top));
        z-index:50;
        background: rgba(255,255,255,.92);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
      }
    }
  </style>
</head>

<body>
  <div class="shell">
    <div class="header">
      <div>
        <div style="display:flex; align-items:center; gap:14px; flex-wrap:wrap;">
          <div class="title">Gare E2K</div>
          <div class="pill" aria-hidden="true"></div>
        </div>
        <div class="subtitle">Marzo 2026 • Seleziona un brand → inserisci la produzione → calcolo automatico soglia e guadagno.</div>
      </div>

      <div class="topActions">
        <button class="btn primary" id="btnCalcAll">CALCOLA TUTTO</button>
        <button class="btn" id="btnReset">RESET</button>
      </div>
    </div>

    <div class="kpis">
      <div class="kpiCard">
        <div class="k">Totale gare singole</div>
        <div class="v" id="kpiSingles">€0</div>
      </div>
      <div class="kpiCard">
        <div class="k">Bonus Multibrand</div>
        <div class="v" id="kpiMB">€0</div>
      </div>
      <div class="kpiCard">
        <div class="k">Totale complessivo</div>
        <div class="v" id="kpiGrand">€0</div>
      </div>
    </div>

    <div class="brandTotals">
      <div class="bCard">
        <div class="bAccent" style="background:var(--acea)"></div>
        <div class="bTop"><div class="bName">ACEA</div><div class="bVal" id="totAcea">€0</div></div>
        <div class="bSub" id="subAcea">-</div>
      </div>

      <div class="bCard">
        <div class="bAccent" style="background:var(--sky)"></div>
        <div class="bTop"><div class="bName">SKY</div><div class="bVal" id="totSky">€0</div></div>
        <div class="bSub" id="subSky">-</div>
      </div>

      <div class="bCard">
        <div class="bAccent" style="background:var(--fastweb)"></div>
        <div class="bTop"><div class="bName">FASTWEB + HO</div><div class="bVal" id="totFastweb">€0</div></div>
        <div class="bSub" id="subFastweb">FW Energy €0 • FW Telco €0 • HO €0</div>
        <div class="bSub" id="subFastweb2">-</div>
      </div>

      <div class="bCard">
        <div class="bAccent" style="background:var(--tiscali)"></div>
        <div class="bTop"><div class="bName">TISCALI</div><div class="bVal" id="totTiscali">€0</div></div>
        <div class="bSub" id="subTiscali">-</div>
        <div class="bSub" id="subTiscali2">-</div>
      </div>

      <div class="bCard">
        <div class="bAccent" style="background:#111827"></div>
        <div class="bTop"><div class="bName">SECONDARI</div><div class="bVal" id="totSecondari">€0</div></div>
        <div class="bSub" id="subSecondari">Efficiency + Rent</div>
      </div>
    </div>

    <div id="errBanner" class="errBanner"></div>

    <div class="insights">
      <div class="insTitle">Suggerimenti Multibrand</div>
      <div class="insLine" id="ins3">✅ Per arrivare a 3 brand: -</div>
      <div class="insLine" id="ins4">✅ Per arrivare a 4 brand: -</div>
      <div class="insLine" id="insPts">🎯 Per prossimo scaglione punti: -</div>
      <div class="insLine" id="insNote"><span>-</span></div>
    </div>

    <div id="dashboard" class="grid">
      <button class="tile" data-open="acea" type="button">
        <div class="accent" style="background:var(--acea)"></div>
        <h3 style="color:var(--acea)">Gara Acea</h3>
        <p>Soglie AUTO • bollettino quantitativo • bonus +3 con FW Energy ≥ 5</p>
      </button>

      <button class="tile" data-open="fwEnergy" type="button">
        <div class="accent" style="background:var(--fastweb)"></div>
        <h3 style="color:var(--fastweb)">Fastweb Energy</h3>
        <p>Res LFM / FLEX / FIX + Business • Tier AUTO 1 / 3 / 7 / 10</p>
      </button>

      <button class="tile" data-open="fwTelco" type="button">
        <div class="accent" style="background:var(--fastweb)"></div>
        <h3 style="color:var(--fastweb)">Fastweb Telco + HO</h3>
        <p>FW Mobile / Wireline / HO • tier AUTO dove previsto + extra quantitativi</p>
      </button>

      <button class="tile" data-open="sky" type="button">
        <div class="accent" style="background:var(--sky)"></div>
        <h3 style="color:var(--sky)">Gara Sky</h3>
        <p>Punti → tier AUTO → compenso + extra trigger unico</p>
      </button>

      <button class="tile" data-open="tiscali" type="button">
        <div class="accent" style="background:var(--tiscali)"></div>
        <h3 style="color:var(--tiscali)">Gara Tiscali</h3>
        <p>Mobile + Fissi + Cyber Security • Marzo 2026</p>
      </button>

      <button class="tile" data-open="multibrand" type="button">
        <div class="accent" style="background:#111827"></div>
        <h3>Multibrand</h3>
        <p>Brand attivi: Fastweb+HO / Sky / Acea / Tiscali</p>
      </button>
    </div>

    <div id="panelWrap" class="panelWrap">

      <!-- ACEA -->
      <div class="panel hide" data-panel="acea">
        <div class="panelHd">
          <div class="left">
            <span class="dot" style="background:var(--acea)"></span>
            <div>
              <div class="t1">Gara Acea</div>
              <div class="t2">Tier AUTO su contratti totali • bollettino quantitativo • bonus FW Energy</div>
            </div>
          </div>
          <div style="display:flex; gap:10px; flex-wrap:wrap;">
            <button class="btn" data-back type="button">⬅︎ Indietro</button>
            <button class="btn primary" data-calc="acea" type="button">Calcola</button>
          </div>
        </div>
        <div class="panelBd">
          <div class="row2">
            <div class="field"><div class="label">ACEA FLEX Casa Luce&Gas</div><input id="acea_flex" type="number" min="0" value="" placeholder="Inserisci quantità" /></div>
            <div class="field"><div class="label">ACEA SPRINT & FIX Casa Luce&Gas</div><input id="acea_sprintfix" type="number" min="0" value="" placeholder="Inserisci quantità" /></div>
            <div class="field"><div class="label">ACEA Business</div><input id="acea_business" type="number" min="0" value="" placeholder="Inserisci quantità" /></div>
            <div class="field"><div class="label">Subentro Luce&Gas</div><input id="acea_subentro" type="number" min="0" value="" placeholder="Inserisci quantità" /></div>
            <div class="field"><div class="label">Nuovo Allaccio Luce&Gas</div><input id="acea_allaccio" type="number" min="0" value="" placeholder="Inserisci quantità" /></div>
            <div class="field">
              <div class="label">Contratti con Bollettino Postale</div>
              <input id="acea_boll_qty" type="number" min="0" value="" placeholder="Quanti contratti a bollettino?" />
              <div class="hint">Viene applicato −20€ solo su questa quantità.</div>
            </div>
          </div>

          <div class="hr"></div>

          <div class="resultBox">
            <div class="rTop">
              <div class="big" id="acea_eur">€0</div>
              <div class="small" id="acea_meta">Contratti: 0 • Tier: -</div>
            </div>
            <div class="mono" id="acea_detail"></div>
          </div>
        </div>
      </div>

      <!-- FASTWEB ENERGY -->
      <div class="panel hide" data-panel="fwEnergy">
        <div class="panelHd">
          <div class="left">
            <span class="dot" style="background:var(--fastweb)"></span>
            <div>
              <div class="t1">Fastweb Energy</div>
              <div class="t2">Tier AUTO su contratti totali Energy (1 / 3 / 7 / 10)</div>
            </div>
          </div>
          <div style="display:flex; gap:10px; flex-wrap:wrap;">
            <button class="btn" data-back type="button">⬅︎ Indietro</button>
            <button class="btn primary" data-calc="fwEnergy" type="button">Calcola</button>
          </div>
        </div>
        <div class="panelBd">
          <div class="row2">
            <div class="field"><div class="label">Res • LIGHT-FULL-MAXI</div><input id="fw_e_lfm" type="number" min="0" value="" placeholder="Inserisci quantità" /></div>
            <div class="field"><div class="label">Res • FLEX</div><input id="fw_e_flex" type="number" min="0" value="" placeholder="Inserisci quantità" /></div>
            <div class="field"><div class="label">Res • FIX</div><input id="fw_e_fix" type="number" min="0" value="" placeholder="Inserisci quantità" /></div>
            <div class="field"><div class="label">Business • FLEX & FIX</div><input id="fw_e_biz" type="number" min="0" value="" placeholder="Inserisci quantità" /></div>
          </div>
          <div class="hr"></div>
          <div class="resultBox">
            <div class="rTop">
              <div class="big" id="fwEnergy_eur">€0</div>
              <div class="small" id="fwEnergy_meta">Contratti: 0 • Tier: -</div>
            </div>
            <div class="mono" id="fwEnergy_detail"></div>
          </div>
        </div>
      </div>

      <!-- FASTWEB TELCO + HO -->
      <div class="panel hide" data-panel="fwTelco">
        <div class="panelHd">
          <div class="left">
            <span class="dot" style="background:var(--fastweb)"></span>
            <div>
              <div class="t1">Fastweb Telco + HO Mobile</div>
              <div class="t2">FW Mobile / Wireline / HO • tier AUTO + extra quantitativi</div>
            </div>
          </div>
          <div style="display:flex; gap:10px; flex-wrap:wrap;">
            <button class="btn" data-back type="button">⬅︎ Indietro</button>
            <button class="btn primary" data-calc="fwTelco" type="button">Calcola</button>
          </div>
        </div>

        <div class="panelBd">
          <div class="subtabs">
            <div class="subbtn active" data-fwtab="mobile">FW Mobile</div>
            <div class="subbtn" data-fwtab="wireline">Wireline</div>
            <div class="subbtn" data-fwtab="ho">HO Mobile</div>
          </div>

          <div class="hr"></div>

          <!-- FW MOBILE -->
          <div id="fwTab_mobile">
            <div class="row2">
              <div class="field">
                <div class="label">Modalità gara Mobile Fastweb</div>
