  function calcFwEnergy(){
    const qLFM = clamp0(qs('#fw_e_lfm').value);
    const qFlex= clamp0(qs('#fw_e_flex').value);
    const qFix = clamp0(qs('#fw_e_fix').value);
    const qBiz = clamp0(qs('#fw_e_biz').value);
    const qty = qLFM + qFlex + qFix + qBiz;
    const tier = pickTierByQty(qty, [1,3,7,10]) || 't1';
    let e=0;
    e += qLFM * (CFG.fwEnergy.res.lfm[tier]||0);
    e += qFlex* (CFG.fwEnergy.res.flex[tier]||0);
    e += qFix * (CFG.fwEnergy.res.fix[tier]||0);
    e += qBiz * (CFG.fwEnergy.bus.flexfix[tier]||0);
    return { qLFM,qFlex,qFix,qBiz, qty, tier, eur:e, next:nextStep(qty,[1,3,7,10]) };
  }

  function calcAcea(fwEnergyQty){
    const Q = {
      flex: clamp0(qs('#acea_flex').value),
      sprintfix: clamp0(qs('#acea_sprintfix').value),
      business: clamp0(qs('#acea_business').value),
      subentro: clamp0(qs('#acea_subentro').value),
      allaccio: clamp0(qs('#acea_allaccio').value),
    };
    const contracts = Object.values(Q).reduce((a,b)=>a+b,0);
    const tier = pickTierByQty(contracts, [1,5,15,30,55]) || 't1';
    const bollQtyRaw = clamp0(qs('#acea_boll_qty').value);
    const bollQty = Math.min(bollQtyRaw, contracts);

    let e = 0;
    for(const k of Object.keys(Q)) e += Q[k] * (CFG.acea.products[k].pay[tier]||0);

    const fwBonusOn = fwEnergyQty >= 5;
    if(fwBonusOn && contracts>0) e += contracts * CFG.acea.fwBonus;
    if(bollQty > 0) e -= bollQty * CFG.acea.bollMinus;

    return { Q, contracts, tier, bollQty, fwBonusOn, eur:e, next:nextStep(contracts,[1,5,15,30,55]) };
  }

  function calcFwMobile(fwEnergyQty){
    const mode = qs('#fw_mobile_mode').value;
    const q1995 = clamp0(qs('#fw_m_1995').value);
    const q1495 = clamp0(qs('#fw_m_1495').value);
    const q1195 = clamp0(qs('#fw_m_1195').value);
    const q995 = clamp0(qs('#fw_m_995').value);
    const autoQtyRaw = clamp0(qs('#fw_auto_qty').value);

    const qty = mode === 'business'
      ? (q1995 + q1495 + q1195)
      : (q1995 + q1495 + q1195 + q995);

    const tier = pickFwMobileTier(qty);
    const t = CFG.fwMobile[mode];
    let e=0;

    if(mode==='business'){
      e += q1995 * (t.perPlan['1995'][tier] || 0);
      e += q1495 * (t.perPlan['1295'][tier] || 0);
      e += q1195 * (t.perPlan['1095'][tier] || 0);
    } else {
      e += q1995 * (t.perPlan['1995'][tier] || 0);
      e += q1495 * (t.perPlan['1495'][tier] || 0);
      e += q1195 * (t.perPlan['1195'][tier] || 0);
      e += q995  * (t.perPlan['995'][tier] || 0);
    }

    const mnpQty = Math.min(clamp0(qs('#fw_m_mnp_qty').value), qty);
    const protectQty = Math.min(clamp0(qs('#fw_m_protect_qty').value), qty);
    const convQty = Math.min(clamp0(qs('#fw_m_conv_qty').value), qty);
    const convEnergyQty = Math.min(clamp0(qs('#fw_m_conv_energy_qty').value), qty);
    const autoQty = Math.min(autoQtyRaw, qty);

    if(mode==='business'){
      e += protectQty * t.extras.protect;
      e += convQty * t.extras.conv;
      e += convEnergyQty * t.extras.convEnergy;
    } else {
      e += mnpQty * t.extras.mnp;
      e += protectQty * t.extras.protect;
      e += convQty * t.extras.conv;
      e += convEnergyQty * t.extras.convEnergy;

      if(mode==='auto'){
        if(fwEnergyQty >= 5) e += autoQty * t.extras.boost5;
        else if(fwEnergyQty >= 2) e += autoQty * t.extras.boost2;
      }
      if(mode==='pura'){
        if(fwEnergyQty >= 5) e += qty * t.extras.boost5;
        else if(fwEnergyQty >= 2) e += qty * t.extras.boost2;
      }
    }

    return {
      mode, tier, q1995,q1495,q1195,q995, qty, autoQty,
      mnpQty, protectQty, convQty, convEnergyQty,
      eur:e, next:nextStep(qty,[10,20,30])
    };
  }

