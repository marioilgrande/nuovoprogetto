    if(pts < 20) return 't12';
    return 't20';
  };
  const pickWirelineTier = (seg, qty)=>{
    if(qty<=0) return 'base';
    if(seg==='bus') return qty>=2 ? 't2' : 'base';
    if(qty>=15) return 't15';
    if(qty>=8) return 't8';
    if(qty>=5) return 't5';
    if(qty>=3) return 't3';
    return 'base';
