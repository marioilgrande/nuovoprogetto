    e += f.f5g * (CFG.tiscali.fixed.f5g[ftier]||0);
    e += f.resFibra * CFG.tiscali.fixed.resFibra.fixed;
    e += f.resFwa * CFG.tiscali.fixed.resFwa.fixed;

    e += cyber.c1 * CFG.tiscali.cyber.c1;
    e += cyber.c2 * CFG.tiscali.cyber.c2;
    e += cyber.c3 * CFG.tiscali.cyber.c3;
    e += cyber.c5 * CFG.tiscali.cyber.c5;
    e += cyber.c10 * CFG.tiscali.cyber.c10;

    const eligibleMobileQty = totalMobile;
    const manualApplied = Math.min(manualQty, eligibleMobileQty);
    e -= manualApplied * 8;

    const noMnpApplied = Math.min(noMnpQty, eligibleMobileQty);
    const avgUnit = eligibleMobileQty > 0 ? (e / Math.max(1,(eligibleMobileQty + totalFixedTierBase + f.resFibra + f.resFwa + cyber.c1 + cyber.c2 + cyber.c3 + cyber.c5 + cyber.c10))) : 0;
    e -= noMnpApplied * (avgUnit * 0.75);

    const totMobileRes = m.m150+m.m200+m.m250+m.m350;
    const totFissoRes = f.resFibra+f.resFwa;
    const totFissoBus = f.power+f.aff2+f.premium+f.premium2+f.f5g;
    const totalItems = totMobileRes + (m.b100+m.b250+m.bunlim+m.b300pro+m.b500pro) + m.connect + totFissoRes + totFissoBus + cyber.c1+cyber.c2+cyber.c3+cyber.c5+cyber.c10;

    return {
      m,f,cyber, eur:round2(e), mtier, ftier,
      totalMobile, totalFixedTierBase, totalItems,
      totMobileRes, totFissoRes, totFissoBus,
      nextMobile:nextStep(totalMobile,[5,10,20]),
      nextFixed:nextStep(totalFixedTierBase,[3,5]),
      manualApplied, noMnpApplied
    };
  }

  function calcEffRent(){
    const lead = clamp0(qs('#eff_lead').value);
    const effC = clamp0(qs('#eff_contract').value);
    const rentC = clamp0(qs('#rent_contract').value);
    return { lead, effC, rentC, totalItems:lead+effC+rentC, eur:0 };
  }

  function calcMultibrand(all){
    const fwBrandActive = (all.fwMobile.qty>=1) && (all.ho.sims>=1) && (all.fwWire.qty>=1) && (all.fwEnergy.qty>=1);
    const skyActive = all.sky.contractsSky >= 1;
    const aceaActive = all.acea.contracts >= 1;
    const tiscaliActive = (all.tiscali.totalMobile>=1) && ((all.tiscali.totFissoRes + all.tiscali.totFissoBus) >= 1);

    let brands = 0;
    if(fwBrandActive) brands++;
    if(skyActive) brands++;
    if(aceaActive) brands++;
    if(tiscaliActive) brands++;

    const pts_fw_mobile = all.fwMobile.qty * CFG.mb.points.fw_mobile_res;
    const pts_ho_mobile = all.ho.sims * CFG.mb.points.ho_mobile_res;
    const pts_fw_fisso = all.fwWire.qty * (all.fwWire.seg==='res' ? CFG.mb.points.fw_fisso_res : CFG.mb.points.fw_fisso_bus);
    const pts_fw_energy = all.fwEnergy.qty * CFG.mb.points.fw_energy;

    const pts_tis_mobile = all.tiscali.totMobileRes * CFG.mb.points.tis_mobile_res;
    const pts_tis_fres = all.tiscali.totFissoRes * CFG.mb.points.tis_fisso_res;
    const pts_tis_fbus = all.tiscali.totFissoBus * CFG.mb.points.tis_fisso_bus;

    const pts_acea = all.acea.contracts * CFG.mb.points.acea_lucegas;
    const pts_sky_contract = all.sky.contractsSky * CFG.mb.points.sky_contract;
    const pts_sky_prova = all.sky.prove * CFG.mb.points.sky_prova;
    const pts_eff_lead = all.effrent.lead * CFG.mb.points.eff_lead;
    const pts_eff_c = all.effrent.effC * CFG.mb.points.eff_contract;
    const pts_rent_c = all.effrent.rentC * CFG.mb.points.rent_contract;

    let pts =
      pts_fw_mobile + pts_ho_mobile + pts_fw_fisso + pts_fw_energy +
      pts_tis_mobile + pts_tis_fres + pts_tis_fbus +
      pts_acea + pts_sky_contract + pts_sky_prova +
      pts_eff_lead + pts_eff_c + pts_rent_c;

    const boost10 = (all.fwEnergy.qty >= 10 && all.acea.contracts >= 10) ? 10 : 0;
    pts += boost10;

    const sorted = [...CFG.mb.bonusTable].sort((a,b)=>a.pts-b.pts);
    const row = sorted.filter(r => pts >= r.pts).sort((a,b)=>b.pts-a.pts)[0] || null;
    const nextRow = sorted.find(r => pts < r.pts) || null;
    const missingPtsToNext = nextRow ? round2(nextRow.pts - pts) : 0;

    let extra = 0;
    if(row){
      if(brands>=4) extra = row.b4;
      else if(brands===3) extra = row.b3;
      else if(brands===2) extra = row.b2;
    }

    const energyContracts = all.acea.contracts + all.fwEnergy.qty;
    const skyContractsForRule = all.sky.contractsSky;
    const extraSkyEnergy = (brands>=4 && skyContractsForRule>=10 && energyContracts>=50) ? CFG.mb.extraSkyEnergy : 0;

    const missingBrands = [];
    if(!fwBrandActive) missingBrands.push({ name:'Fastweb+HO', rule:'Serve 1 FW Mobile + 1 HO + 1 Wireline + 1 Energy' });
    if(!skyActive) missingBrands.push({ name:'Sky', rule:'Serve almeno 1 contratto Sky' });
    if(!aceaActive) missingBrands.push({ name:'Acea', rule:'Serve almeno 1 contratto Acea' });
    if(!tiscaliActive) missingBrands.push({ name:'Tiscali', rule:'Serve 1 mobile + 1 fisso Tiscali' });

    return {
      pts:round2(pts),
      brands,
      fwBrandActive, skyActive, aceaActive, tiscaliActive,
      boost10,
      row, nextRow, missingPtsToNext,
      tokenNow:tokenForBrandCount(brands,row),
      tokenNextPts:tokenForBrandCount(brands,nextRow),
      missingBrands,
      extra, extraSkyEnergy,
      bonus:extra + extraSkyEnergy,
      energyContracts, skyContractsForRule
    };
  }

