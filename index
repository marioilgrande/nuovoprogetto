  const pickTierByQty = (qty, thresholds)=>{
    if(qty<=0) return null;
    let best = thresholds[0];
    for(const t of thresholds){ if(qty>=t) best=t; }
    return 't' + String(best);
  };
  const pickFwMobileTier = (qty)=>{
    if(qty>=30) return 't30';
