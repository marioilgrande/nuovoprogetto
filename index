  function openPanel(key){
    const dash = qs('#dashboard');
    const wrap = qs('#panelWrap');
    dash.style.display = 'none';
    wrap.style.display = 'block';

    qsa('[data-panel]').forEach(p=> p.classList.add('hide'));
    const panel = qs(`[data-panel="${key}"]`);
    if(panel) panel.classList.remove('hide');

    requestAnimationFrame(()=>{
      requestAnimationFrame(()=>{
        const firstField = panel ? panel.querySelector('.panelBd') : null;
        if(firstField) firstField.scrollIntoView({behavior:'smooth', block:'start'});
        else window.scrollTo({top:0, behavior:'smooth'});
      });
    });

    scheduleRender();
  }

  function backToDashboard(){
    qs('#panelWrap').style.display = 'none';
    qs('#dashboard').style.display = 'grid';
    requestAnimationFrame(()=> window.scrollTo({top:0, behavior:'smooth'}));
    scheduleRender();
  }

  function setFwTab(name){
    qsa('[data-fwtab]').forEach(b=> b.classList.toggle('active', b.dataset.fwtab===name));
    qs('#fwTab_mobile').classList.toggle('hide', name!=='mobile');
    qs('#fwTab_wireline').classList.toggle('hide', name!=='wireline');
    qs('#fwTab_ho').classList.toggle('hide', name!=='ho');
    scheduleRender();
  }

  function setTisTab(name){
    qsa('[data-tistab]').forEach(b=> b.classList.toggle('active', b.dataset.tistab===name));
    qs('#tisTab_tiscali').classList.toggle('hide', name!=='tiscali');
    qs('#tisTab_effrent').classList.toggle('hide', name!=='effrent');
    scheduleRender();
  }

  function refreshWirelineUI(){
    const seg = qs('#fw_w_segment').value;
    qs('#wireline_res').classList.toggle('hide', seg!=='res');
    qs('#wireline_bus').classList.toggle('hide', seg!=='bus');
    scheduleRender();
  }

  function adaptMobileMode(){
    const mode = qs('#fw_mobile_mode').value;
    const inp995 = qs('#fw_m_995');

    if(mode==='business'){
      qs('#lbl_fw_m_1495').textContent = 'SIM 12,95€';
      qs('#lbl_fw_m_1195').textContent = 'SIM 10,95€';
      qs('#lbl_fw_m_995').textContent = 'SIM 9,95€ (non usata in Business)';
      qs('#lbl_fw_m_conv').textContent = 'Convergenza';
      qs('#lbl_fw_m_conv_energy').textContent = 'SIM con almeno 1 Energy';
      qs('#hint_fw_m_conv').textContent = 'Numero contratti in convergenza (+25€).';
      qs('#hint_fw_m_conv_energy').textContent = 'Numero SIM con almeno 1 Energy (+2€).';
      qs('#fw_mobile_boost_hint').textContent = 'Business: il tier è AUTO su quantità totali.';
      inp995.value = '';
      inp995.disabled = true;
      qs('#fw_m_mnp_qty').value = '';
      qs('#fw_m_mnp_qty').disabled = true;
      qs('#fw_auto_qty').value = '';
      qs('#fw_auto_qty').disabled = true;
    } else {
      qs('#lbl_fw_m_1495').textContent = 'SIM 14,95€';
      qs('#lbl_fw_m_1195').textContent = 'SIM 11,95€';
      qs('#lbl_fw_m_995').textContent = 'SIM 9,95€';
      qs('#lbl_fw_m_conv').textContent = 'Convergenza';
      qs('#lbl_fw_m_conv_energy').textContent = 'Convergenza con Energy';
      qs('#hint_fw_m_conv').textContent = 'Numero contratti in convergenza standard.';
      qs('#hint_fw_m_conv_energy').textContent = 'Numero contratti in convergenza con Energy.';
      qs('#fw_mobile_boost_hint').textContent = 'FW AUTO/PURA: bonus extra in base ai contratti FW Energy.';
      qs('#fw_m_mnp_qty').disabled = false;
      qs('#fw_auto_qty').disabled = false;
      inp995.disabled = false;
    }

    qs('#fw_mobile_tier_hint').textContent = 'Calcolo automatico su SIM totali: base / 10 / 20 / 30';
    scheduleRender();
  }

  function bind(){
    qsa('[data-open]').forEach(t=> t.addEventListener('click', ()=> openPanel(t.dataset.open)));
    qsa('[data-back]').forEach(b=> b.addEventListener('click', backToDashboard));

    qs('#btnCalcAll').addEventListener('click', ()=> renderAll());
    qsa('[data-calc]').forEach(b=> b.addEventListener('click', ()=> renderAll()));

    qs('#btnReset').addEventListener('click', ()=>{
      qsa('input[type="number"]').forEach(i=> i.value = '');

      qs('#fw_mobile_mode').value = 'auto';
      qs('#fw_w_segment').value = 'res';
      qs('#ho_mode').value = 'auto';

      refreshWirelineUI();
      adaptMobileMode();
      setFwTab('mobile');
      setTisTab('tiscali');
      renderAll();
    });

    qsa('input,select').forEach(el=>{
      el.addEventListener('input', scheduleRender, {passive:true});
      el.addEventListener('change', scheduleRender, {passive:true});
    });

    qsa('[data-fwtab]').forEach(b=> b.addEventListener('click', ()=> setFwTab(b.dataset.fwtab)));
    qsa('[data-tistab]').forEach(b=> b.addEventListener('click', ()=> setTisTab(b.dataset.tistab)));

    qs('#fw_w_segment').addEventListener('change', refreshWirelineUI);
    qs('#fw_mobile_mode').addEventListener('change', adaptMobileMode);

    refreshWirelineUI();
    adaptMobileMode();
    setFwTab('mobile');
    setTisTab('tiscali');
    renderAll();
  }

  document.addEventListener('DOMContentLoaded', ()=>{
    try{ bind(); }
    catch(e){
      showErr("Errore JS durante init:\n" + (e?.stack || e));
      console.error(e);
    }
  });
})();
