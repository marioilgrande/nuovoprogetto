    const totalFixedTierBase = f.power+f.aff2+f.premium+f.premium2+f.f5g;
    const mtier = pickTiscaliMobileTier(totalMobile > 0 ? totalMobile : 1);
    const ftier = pickTiscaliFixedTier(totalFixedTierBase > 0 ? totalFixedTierBase : 1);

    let e=0;
    e += m.m150 * (CFG.tiscali.mobile.m150[mtier]||0);
