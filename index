<script>
(function(){
  const qs = (s, r=document)=> r.querySelector(s);
  const qsa = (s, r=document)=> Array.from(r.querySelectorAll(s));

  const eur = (n)=> new Intl.NumberFormat('it-IT',{style:'currency',currency:'EUR',maximumFractionDigits:0}).format(Number(n||0));
  const num = (v)=> {
    const x = Number(String(v ?? '').replace(',','.'));
    return Number.isFinite(x) ? x : 0;
  };
  const clamp0 = (n)=> Math.max(0, Math.floor(num(n)));
  const round2 = (n)=> Math.round((Number(n||0) + Number.EPSILON) * 100) / 100;

  const showErr = (msg)=>{
    const el = qs('#errBanner');
    el.style.display = 'block';
    el.textContent = msg;
  };

  let _raf = 0;
  function scheduleRender(){
    if(_raf) cancelAnimationFrame(_raf);
    _raf = requestAnimationFrame(()=>{
      _raf = 0;
      renderAll();
    });
  }

  function nextStep(qty, steps){
    const q = Number(qty||0);
    for(const s of steps){
      if(q < s) return { next:s, missing:round2(s-q), hasNext:true };
    }
    return { next:null, missing:0, hasNext:false };
  }
  function fmtNextStep(qty, steps, label){
    const ns = nextStep(qty, steps);
    if(!ns.hasNext) return 'Max tier';
    return `Prossima ${label}: ${ns.next} (mancano ${ns.missing})`;
  }
